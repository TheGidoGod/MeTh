<svg width="1200" height="800" viewBox="0 0 1200 800" fill="none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg" x1="120" y1="80" x2="1060" y2="700" gradientUnits="userSpaceOnUse">
      <stop stop-color="#1FE3F0"/>
      <stop offset="0.48" stop-color="#FF4FA0"/>
      <stop offset="1" stop-color="#FFB84D"/>
    </linearGradient>
    <linearGradient id="screen" x1="458" y1="208" x2="741" y2="463" gradientUnits="userSpaceOnUse">
      <stop stop-color="#22113E"/>
      <stop offset="1" stop-color="#101B49"/>
    </linearGradient>
    <filter id="glow" x="-80" y="-80" width="1360" height="960" filterUnits="userSpaceOnUse" color-interpolation-filters="sRGB">
      <feGaussianBlur stdDeviation="24"/>
    </filter>
  </defs>

  <rect width="1200" height="800" rx="44" fill="#120A24"/>
  <g opacity="0.7" filter="url(#glow)">
    <circle cx="220" cy="160" r="120" fill="#1FE3F0"/>
    <circle cx="965" cy="170" r="130" fill="#FF4FA0"/>
    <circle cx="960" cy="620" r="150" fill="#FFB84D"/>
  </g>

  <rect x="116" y="124" width="968" height="552" rx="36" fill="url(#bg)" opacity="0.18"/>
  <rect x="290" y="118" width="620" height="480" rx="36" fill="#22143D" stroke="#F9FBFF" stroke-opacity="0.22" stroke-width="6"/>
  <rect x="338" y="166" width="524" height="316" rx="28" fill="url(#screen)" stroke="#65E8FF" stroke-opacity="0.65" stroke-width="6"/>

  <path d="M404 272H516" stroke="#28E4EE" stroke-width="26" stroke-linecap="round"/>
  <path d="M460 216V328" stroke="#28E4EE" stroke-width="26" stroke-linecap="round"/>
  <circle cx="621" cy="272" r="24" fill="#FFCF5A"/>
  <circle cx="712" cy="272" r="24" fill="#FF5D8F"/>
  <path d="M431 364C482 430 540 462 605 462C670 462 728 430 779 364" stroke="#A983FF" stroke-width="20" stroke-linecap="round"/>

  <rect x="420" y="530" width="364" height="38" rx="19" fill="#FFE9F5" fill-opacity="0.16"/>
  <circle cx="490" cy="549" r="18" fill="#FF5D8F"/>
  <circle cx="601" cy="549" r="18" fill="#1FE3F0"/>
  <circle cx="712" cy="549" r="18" fill="#FFB84D"/>

  <g opacity="0.95">
    <circle cx="180" cy="562" r="58" fill="#1B1233" stroke="#1FE3F0" stroke-opacity="0.8" stroke-width="5"/>
    <path d="M151 562H209" stroke="#1FE3F0" stroke-width="15" stroke-linecap="round"/>
    <path d="M180 533V591" stroke="#1FE3F0" stroke-width="15" stroke-linecap="round"/>

    <circle cx="1020" cy="564" r="58" fill="#1B1233" stroke="#FFCF5A" stroke-opacity="0.8" stroke-width="5"/>
    <path d="M992 536L1048 592" stroke="#FFCF5A" stroke-width="15" stroke-linecap="round"/>
    <path d="M1048 536L992 592" stroke="#FFCF5A" stroke-width="15" stroke-linecap="round"/>
  </g>

  <g fill="#F8FBFF">
    <text x="165" y="232" font-size="72" font-family="Fredoka, Arial, sans-serif" font-weight="700">MATH</text>
    <text x="165" y="300" font-size="72" font-family="Fredoka, Arial, sans-serif" font-weight="700">ARCADE</text>
  </g>
  <text x="165" y="368" font-size="28" font-family="Fredoka, Arial, sans-serif" fill="#DDE8FF" opacity="0.85">Playful practice, bright streaks, instant wins.</text>
</svg>
